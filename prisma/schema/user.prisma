enum Role {
  ADMIN
  MANAGER
  TECHNICIAN
}

model User {
  id        String   @id @default(uuid())
  userName  String   @unique
  email     String   @unique
  password  String
  roles     Role[]   @default([TECHNICIAN])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]   

  @@map("users")
}
