enum NotificationType {
  LOW_STOCK
  OUT_OF_STOCK
  TASK_OVERDUE
}

model Notification {
  id              String           @id @default(uuid())
  type            NotificationType
  message         String
  isRead          Boolean          @default(false)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  // References the entity that triggered the notification.
  // Used to prevent duplicate notifications for the same active condition
  // (e.g. LOW_STOCK for the same inventory item).
  relatedEntityId String?
  createdAt       DateTime         @default(now())

  // Optimizes duplicate-notification checks for system jobs.
  @@index([type, relatedEntityId, isRead])
  @@map("notifications")
}

